{
  "problemMatcher": [
    {
      "owner": "tflint",
      "pattern": [
        {
          "regexp": "^(.+):(\\d+):(\\d+): (Error|Warning|Notice) - (.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      ]
    }
  ]
}
